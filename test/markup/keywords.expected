<span class="hljs-comment"># Testing specific testing modifiers inside check blocks</span>
<span class="hljs-keyword">check</span> <span class="hljs-string">&quot;testing constructs&quot;</span>:
  <span class="hljs-function"><span class="hljs-keyword">fun</span> <span class="hljs-title">f</span><span class="hljs-params">()</span></span>: raise(<span class="hljs-string">&quot;err&quot;</span>) <span class="hljs-keyword">end</span>
  
  <span class="hljs-number">1</span> <span class="hljs-keyword">is</span><span class="hljs-operator">==</span> <span class="hljs-number">1</span>
  <span class="hljs-number">1</span> <span class="hljs-keyword">is</span><span class="hljs-operator">=</span>~ <span class="hljs-number">1.0</span>
  <span class="hljs-number">1</span> <span class="hljs-keyword">is</span><span class="hljs-operator">&lt;=</span><span class="hljs-operator">&gt;</span> <span class="hljs-number">1</span>
  <span class="hljs-number">1</span> <span class="hljs-keyword">is-not</span><span class="hljs-operator">==</span> <span class="hljs-number">2</span>
  <span class="hljs-number">1</span> <span class="hljs-keyword">is-not</span><span class="hljs-operator">=</span>~ <span class="hljs-number">2.0</span>
  <span class="hljs-number">1</span> <span class="hljs-keyword">is-not</span><span class="hljs-operator">&lt;=</span><span class="hljs-operator">&gt;</span> <span class="hljs-number">2</span>
  <span class="hljs-number">1</span> <span class="hljs-keyword">is-not</span> <span class="hljs-number">2</span>
  
  <span class="hljs-number">1.1</span> <span class="hljs-keyword">is-roughly</span> <span class="hljs-number">1.1</span>
  <span class="hljs-number">1.1</span> <span class="hljs-keyword">is-not-roughly</span> <span class="hljs-number">2.0</span>
  
  f() <span class="hljs-keyword">raises-other-than</span> <span class="hljs-string">&quot;wrong err&quot;</span>
  f() <span class="hljs-keyword">does-not-raise</span>
  f() <span class="hljs-keyword">raises-satisfies</span> <span class="hljs-function"><span class="hljs-keyword">lam</span><span class="hljs-params">(e)</span></span>: <span class="hljs-literal">true</span> <span class="hljs-keyword">end</span>
  f() <span class="hljs-keyword">raises-violates</span> <span class="hljs-function"><span class="hljs-keyword">lam</span><span class="hljs-params">(e)</span></span>: <span class="hljs-literal">false</span> <span class="hljs-keyword">end</span>
<span class="hljs-keyword">end</span>